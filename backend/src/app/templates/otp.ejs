<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Verify Your Email</title>
</head>
<body style="font-family: sans-serif; background-color: #f4f4f4; padding: 20px;">
    <div style="max-width: 600px; margin: 0 auto; background-color: #ffffff; padding: 40px; border-radius: 8px;">
        <h2 style="color: #333333;">Verification Code</h2>
        <p style="color: #666666; font-size: 16px;">Hello <%= name %>,</p>
        <p style="color: #666666; font-size: 16px;">Your verification code is:</p>
        <div style="background-color: #f0f0f0; padding: 20px; text-align: center; font-size: 32px; font-weight: bold; letter-spacing: 5px; margin: 20px 0; border-radius: 4px; color: #1a73e8;">
            <%= otp %>
        </div>
        <p style="color: #666666; font-size: 14px;">This code will expire in 5 minutes.</p>
        <p style="color: #999999; font-size: 12px; margin-top: 40px;">If you did not request this, please ignore this email.</p>
    </div>
</body>
</html>
